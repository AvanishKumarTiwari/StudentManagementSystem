<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudentManagementSystem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StudentManagementSystem.styles.css" asp-append-version="true" />

    <style>
        /* Only navbar styling (matches Bootstrap primary theme) */

        .top-navbar {
            background: linear-gradient(135deg,#4e73df,#1cc88a)
        }

        .navbar-brand {
            font-weight: 600;
            color: white !important;
        }

        .nav-link {
            color: white !important;
        }

            .nav-link:hover {
                opacity: .85;
            }
    </style>
    @RenderSection("Styles", required: false)

</head>

<body>

    @{
        var cookies = ViewContext.HttpContext.Request.Cookies;
        var authRole = (cookies["AuthRole"] ?? string.Empty);
    }

    <header>

        <nav class="navbar navbar-expand-lg top-navbar">
            <div class="container">

                <a class="navbar-brand ml-10"  asp-controller="Home" asp-action="Index">
                    <i class="bi bi-mortarboard-fill"></i>
                    Student Management System
                </a>

                <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="#">Students</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="#">Courses</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>

                        @if (!string.IsNullOrEmpty(authRole))
                        {
                            <li class="nav-item">
                                <form method="post" asp-controller="Admin" asp-action="Logout" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-light ms-2">Logout (@authRole)</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="AdminLogin">Admin Login</a>
                            </li>
                        }

                    </ul>
                </div>

            </div>
        </nav>

        <!-- sidebar moved into page container so it aligns with main content -->
    </header>

    <div class="container-fluid mt-4">
        <div class="row">
            <aside class="col-lg-2 col-md-3 sidebar p-3 d-none d-md-block">
                @{
                    var currentController = (ViewContext.RouteData.Values["controller"] ?? string.Empty).ToString();
                    var currentAction = (ViewContext.RouteData.Values["action"] ?? string.Empty).ToString();

                    bool IsActive(string ctrl, string act = null)
                    {
                        var matchCtrl = string.Equals(currentController, ctrl, StringComparison.OrdinalIgnoreCase);
                        if (act == null) return matchCtrl;
                        var matchAct = string.Equals(currentAction, act, StringComparison.OrdinalIgnoreCase);
                        return matchCtrl && matchAct;
                    }
                }

                <h4 class="text-white mb-4">Admin Panel</h4>

                

                <a class="@(IsActive("Home", "Index") ? "active sidebar-link" : "sidebar-link")" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                <a class="@(IsActive("Admin", "Users") ? "active sidebar-link" : "sidebar-link")" asp-controller="Admin" asp-action="Users">
                    <i class="bi bi-people"></i> Users
                </a>

                <a class="sidebar-link" href="#"><i class="bi bi-person-badge"></i> Admins</a>

                <a class="@(IsActive("Admin", "Products") ? "active sidebar-link" : "sidebar-link")" asp-controller="Admin" asp-action="Products">
                    <i class="bi bi-box"></i> Products
                </a>

                @if (string.IsNullOrEmpty(authRole))
                {
                    <a class="@(IsActive("Admin", "AdminLogin") ? "active sidebar-link" : "sidebar-link")" asp-controller="Admin" asp-action="AdminLogin">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </a>

                    <a class="@(IsActive("Admin", "AdminRegister") ? "active sidebar-link" : "sidebar-link")" asp-controller="Admin" asp-action="AdminRegister">
                        <i class="bi bi-person-plus"></i> Register (Admin)
                    </a>

                    <a class="@(IsActive("HOD", "HODinfo") ? "active sidebar-link" : "sidebar-link")" asp-controller="HOD" asp-action="HODinfo">
                        <i class="bi bi-person-badge"></i> Register (HOD)
                    </a>
                }
                else
                {
                    <a class="sidebar-link" href="#"><i class="bi bi-person-circle"></i> @authRole</a>

                    <form method="post" asp-controller="Admin" asp-action="Logout" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link sidebar-link p-0" style="color:inherit; text-decoration:none;">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                }
            </aside>

            <div class="col-lg-10 col-md-9">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <style>
        /* Sidebar styling to match navbar */
        .sidebar {
            background: linear-gradient(135deg,#4e73df,#1cc88a);
            min-height: calc(100vh - 120px);
            color: white;
        }

        .sidebar-link {
            color: white !important;
            display: block;
            padding: 8px 0;
            text-decoration: none;
            border-radius: 6px;
            padding-left: .25rem;
        }

        .sidebar-link i { margin-right: .5rem; }

        .sidebar-link.active,
        .sidebar-link:hover {
            background: rgba(255,255,255,0.08);
            color: #fff !important;
        }
    </style>

    <footer class="border-top footer text-muted">
        <div class="container py-3">
            &copy; 2026 - StudentManagementSystem
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>