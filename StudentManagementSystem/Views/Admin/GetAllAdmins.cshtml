@model IEnumerable<StudentManagementSystem.Models.Admin>

@{
    ViewData["Title"] = "GetAllAdmins";
}

<h3>Admins</h3>

<p>
    <a class="btn btn-primary" asp-action="CreateAdmin">Create New Admin</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach(var a in Model) {
        <tr>
            <td>@a.Id</td>
            <td>@a.FullName</td>
            <td>@a.Email</td>
            <td>@a.Phone</td>
            <td>
                <a asp-action="EditAdmin" asp-route-id="@a.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="DeleteAdmin" asp-route-id="@a.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
